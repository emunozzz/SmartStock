# ==========================================
# Plantilla de variables de entorno - SmartStock Backend
# Copia este archivo como ".env" y reemplaza los valores
# con tus credenciales reales. NUNCA subas tu ".env" real a Git.
# ==========================================

# Base de datos PostgreSQL
# Formato: postgresql://usuario:contrasena@host:puerto/nombre_bd
#DATABASE_URL=postgresql://postgres:tu_contrasena@localhost:5432/smartstock_db

# Seguridad / JWT
# Genera una clave propia con:
# python -c "import secrets; print(secrets.token_hex(32))"
#SECRET_KEY=70052f6910bd33e0921a6a3b58220fb1e1ce6b38adba9504fdc22c40fcd616c1


# Modo de la aplicación
#DEBUG=True

# Groq (para módulo de predicción de demanda) - Gratis en console.groq.com
#GROQ_API_KEY=gsk_tu-api-key-aqui
#GROQ_MODEL=llama-3.3-70b-versatile
